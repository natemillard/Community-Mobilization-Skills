---
import { getCollection, getEntry } from 'astro:content';
import SkillLayout from '../../layouts/SkillLayout.astro';

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  return skills.map(skill => ({
    params: { slug: skill.slug },
    props: { skill },
  }));
}

const { skill } = Astro.props;
const { Content } = await skill.render();
const {
  title, skillNumber, phase, combines, accentColor,
  priorSkills, keyMindsets, keyFrameworks,
  prevSkill, nextSkill,
} = skill.data;
---

<SkillLayout
  title={title}
  skillNumber={skillNumber}
  phase={phase}
  combines={combines}
  accentColor={accentColor}
  priorSkills={priorSkills}
  keyMindsets={keyMindsets}
  keyFrameworks={keyFrameworks}
  prevSkill={prevSkill}
  nextSkill={nextSkill}
>
  <div class="skill-content">
    <Content />
  </div>
</SkillLayout>

<style>
  /* Style markdown output from Content collection */
  .skill-content :global(h2) {
    font-size: 1.375rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--rule);
    font-family: var(--font-display);
  }
  .skill-content :global(h2:first-child) {
    margin-top: 0;
  }
  .skill-content :global(p) {
    color: var(--ink-2);
    margin-bottom: 0.875rem;
    max-width: 68ch;
  }
  .skill-content :global(ul),
  .skill-content :global(ol) {
    padding-left: 1.25rem;
    color: var(--ink-2);
    margin-bottom: 0.875rem;
  }
  .skill-content :global(li) {
    margin-bottom: 0.375rem;
  }
  .skill-content :global(strong) {
    font-weight: 600;
    color: var(--ink);
  }
  .skill-content :global(em) {
    font-style: italic;
  }
  /* Proficiency table */
  .skill-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9375rem;
  }
  .skill-content :global(thead tr) {
    background: var(--surf-2);
  }
  .skill-content :global(th) {
    text-align: left;
    padding: 0.625rem 0.875rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-3);
    border-bottom: 2px solid var(--rule);
  }
  .skill-content :global(td) {
    padding: 0.875rem;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
    color: var(--ink-2);
  }
  .skill-content :global(tr td:first-child) {
    font-weight: 600;
    color: var(--ink);
    white-space: nowrap;
    width: 180px;
  }
  /* Definition block — style the first blockquote as definition */
  .skill-content :global(blockquote) {
    border-left: 4px solid var(--people);
    padding: 1.25rem 1.5rem;
    background: var(--surf-2);
    border-radius: 0 var(--r-md) var(--r-md) 0;
    margin: 1.5rem 0;
    font-style: italic;
  }
  .skill-content :global(blockquote p) {
    font-family: var(--font-display);
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--ink);
    max-width: none;
    margin: 0;
  }
  /* Numbered guiding questions */
  .skill-content :global(ol) {
    list-style: none;
    padding: 0;
    counter-reset: q;
  }
  .skill-content :global(ol li) {
    counter-increment: q;
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--rule);
    font-style: italic;
    color: var(--ink-2);
  }
  .skill-content :global(ol li:last-child) {
    border-bottom: none;
  }
  .skill-content :global(ol li::before) {
    content: counter(q);
    font-weight: 700;
    font-family: var(--font-display);
    font-style: normal;
    color: var(--ink-3);
    font-size: 0.875rem;
  }
</style>
