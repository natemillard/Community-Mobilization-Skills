---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allSkills = await getCollection('skills', ({ data }) => !data.draft);
const skills = allSkills.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="The 10 Skills" description="The 10 core community mobilization skills — organized along the chapter journey.">

  <section class="hero">
    <div class="container">
      <span class="eyebrow">The 10 core skills</span>
      <h1>From the inside out.</h1>
      <p class="lead">
        These skills are organized along the chapter journey — starting with self-discovery and moving outward through relational, analytical, facilitation, strategy, and sustainability skills.
      </p>
    </div>
  </section>

  <section class="section" style="padding: 2.5rem 0;">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1px; background: var(--rule); border-radius: var(--r-lg); overflow: hidden;">
        {[
          { level: 'Understand It',      bloom: 'Remember · Understand', note: 'I can explain this in my own words.' },
          { level: 'Can Do It',          bloom: 'Apply',                  note: 'I have practiced this with support.' },
          { level: 'Do It Consistently', bloom: 'Analyze · Evaluate',    note: 'I use this regularly and adapt it.' },
          { level: 'Coach Others',       bloom: 'Create · Synthesize',   note: 'I help others develop this skill.' },
        ].map(l => (
          <div style="background: var(--white); padding: 1.25rem;">
            <div style="font-weight: 600; font-size: 0.9375rem; margin-bottom: 0.25rem;">{l.level}</div>
            <div style="font-size: 0.75rem; color: var(--ink-3); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.06em;">{l.bloom}</div>
            <div style="font-size: 0.875rem; color: var(--ink-2); font-style: italic;">{l.note}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 1rem;">
    <div class="container">
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        {skills.map(skill => (
          <a href={`/skills/${skill.slug}`} style="text-decoration: none; color: inherit;">
            <div class="card" style="flex-direction: row; align-items: center; gap: 2rem; padding: 1.5rem 2rem;">
              <div style={`width: 48px; height: 48px; border-radius: 50%; background: ${skill.data.accentColor}; display: flex; align-items: center; justify-content: center; flex-shrink: 0;`}>
                <span style="font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; color: rgba(255,255,255,0.9);">{skill.data.skillNumber}</span>
              </div>
              <div style="flex: 1; min-width: 0;">
                <div style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 0.25rem;">{skill.data.phase}</div>
                <h3 style="font-size: 1.0625rem; margin-bottom: 0.25rem;">{skill.data.title}</h3>
                <p style="font-size: 0.875rem; color: var(--ink-3); font-style: italic; margin: 0; max-width: none;">{skill.data.combines}</p>
              </div>
              <div style="flex-shrink: 0; font-size: 1.25rem; color: var(--ink-3);">→</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
