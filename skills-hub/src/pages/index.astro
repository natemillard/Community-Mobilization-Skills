---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  { num: 'S1',  title: 'Self-Discovery',                             href: '/skills/self-discovery',          color: '#552F1C', phase: 'Preconditions' },
  { num: 'S2',  title: 'Trust-Building Conversations',               href: '/skills/trust-building',          color: '#225A7B', phase: 'Preconditions' },
  { num: 'S3',  title: 'Who Speaks Matters',                         href: '/skills/who-speaks-matters',      color: '#BD2F2E', phase: 'Throughout' },
  { num: 'S4',  title: 'Linking People and Possibilities',           href: '/skills/linking-people',          color: '#557A35', phase: 'Asset Mapping' },
  { num: 'S5',  title: 'Data-Informed Learning',                     href: '/skills/data-informed-learning',  color: '#0097B2', phase: 'Priority Area' },
  { num: 'S6',  title: 'Purposeful Meetings',                        href: '/skills/purposeful-meetings',     color: '#004AAD', phase: 'Community Discovery' },
  { num: 'S7',  title: 'Decision-Making Without Authority',          href: '/skills/decision-making',         color: '#C96845', phase: 'Planning' },
  { num: 'S8',  title: 'Strategic Prioritization',                   href: '/skills/strategic-prioritization',color: '#CA9B33', phase: 'Planning' },
  { num: 'S9',  title: 'Building Across Levels',                     href: '/skills/building-across-levels',  color: '#7F4D94', phase: 'Planning' },
  { num: 'S10', title: 'Community Program Support',                  href: '/skills/community-program-support',color: '#00BE88', phase: 'Sustaining' },
];
---

<BaseLayout title="Home" description="A learning resource for community mobilization practitioners — skills, practices, and tools for building resilient communities.">

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <span class="eyebrow">Community Mobilization Skills Hub</span>
      <h1 class="text-balance">Building the skills<br/>that move communities.</h1>
      <p class="lead">
        A practical learning resource for Executive Directors and community mobilization practitioners — 10 core skills for lasting, equitable change.
      </p>
      <div class="hero-actions">
        <a href="/skills" class="btn btn-primary">Explore the skills →</a>
        <a href="/overview" class="btn btn-outline">What is community mobilization?</a>
      </div>
    </div>
  </section>

  <!-- SKILLS GRID -->
  <section class="section">
    <div class="container">
      <span class="section-label">The 10 core skills</span>
      <h2>From the inside out</h2>
      <p style="color: var(--ink-2); font-size: 1.0625rem; margin-bottom: 2.5rem; max-width: 58ch;">
        These skills are organized along the chapter journey — starting with the internal work of self-discovery and moving outward through relational, analytical, and systems-level practice.
      </p>
      <div class="grid-2">
        {skills.map(skill => (
          <a href={skill.href} class="card">
            <span class="card-pip" style={`background: ${skill.color};`}></span>
            <span class="card-meta">{skill.num} · {skill.phase}</span>
            <h3>{skill.title}</h3>
            <span class="card-arrow">Learn this skill →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
        <div>
          <span class="section-label">About this resource</span>
          <h2>Built for practitioners, by practitioners.</h2>
          <p style="color: var(--ink-2); margin-bottom: 1rem;">
            This hub is a companion to the Community Mobilization Field Manual — bringing the 10 core skills to life with definitions, examples, guiding questions, and proficiency frameworks.
          </p>
          <p style="color: var(--ink-2); margin-bottom: 2rem;">
            Whether you are just beginning to explore community mobilization or looking to deepen your practice, these resources meet you where you are.
          </p>
          <a href="/about" class="btn btn-outline">Learn more about this project</a>
        </div>
        <div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--rule); border-radius: var(--r-lg); overflow: hidden;">
            {[
              { label: '10', desc: 'Core skills' },
              { label: '4', desc: 'Proficiency levels' },
              { label: '6', desc: 'Journey phases' },
              { label: '1', desc: 'Goal: thriving communities' },
            ].map(stat => (
              <div style="background: var(--white); padding: 2rem;">
                <div style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 600; color: var(--ink); line-height: 1;">{stat.label}</div>
                <div style="font-size: 0.875rem; color: var(--ink-3); margin-top: 0.375rem;">{stat.desc}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CHAPTER JOURNEY -->
  <section class="section" style="background: var(--surf-2);">
    <div class="container">
      <span class="section-label">The chapter journey</span>
      <h2>A circular, recursive path</h2>
      <p style="color: var(--ink-2); margin-bottom: 2.5rem; max-width: 58ch;">
        Community mobilization is not a project with a start and end date. It is a cycle that a chapter returns to, deepens, and begins again.
      </p>
      <div style="display: flex; gap: 0; overflow-x: auto; border-radius: var(--r-md); overflow: hidden; border: 1px solid var(--rule);">
        {[
          { phase: 'Preconditions',          color: '#552F1C', sub: 'Know yourself · Build the team' },
          { phase: 'Asset Mapping',           color: '#557A35', sub: 'Discover what you have' },
          { phase: 'Priority Area',           color: '#CA9B33', sub: 'Decide where to focus' },
          { phase: 'Community Discovery',     color: '#0097B2', sub: 'Listen before planning' },
          { phase: 'Planning & Execution',    color: '#7F4D94', sub: 'Design layered strategy' },
          { phase: 'Sustaining & Transfer',   color: '#00BE88', sub: 'Hand it back · Begin again' },
        ].map(p => (
          <div style={`flex: 1; min-width: 140px; background: ${p.color}; padding: 1.25rem 1rem;`}>
            <div style="font-size: 0.8125rem; font-weight: 700; color: rgba(255,255,255,0.9); margin-bottom: 0.375rem; line-height: 1.3;">{p.phase}</div>
            <div style="font-size: 0.75rem; color: rgba(255,255,255,0.65); line-height: 1.4;">{p.sub}</div>
          </div>
        ))}
      </div>
      <p style="color: var(--ink-3); font-size: 0.875rem; margin-top: 1rem; font-style: italic;">
        ↻ This process is recursive — chapters return to earlier phases as they learn, grow, and begin again with new priorities.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <h2 style="margin-bottom: 1rem;">Ready to go deeper?</h2>
      <p style="color: var(--ink-2); margin: 0 auto 2rem; max-width: 46ch;">
        Explore the full skills library, read the community mobilization overview, or check out the MOBILIZE game — coming soon.
      </p>
      <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
        <a href="/skills" class="btn btn-primary">Browse all 10 skills</a>
        <a href="/overview" class="btn btn-outline">Read the overview</a>
        <a href="/mobilize" class="btn btn-outline">MOBILIZE game</a>
      </div>
    </div>
  </section>

</BaseLayout>
